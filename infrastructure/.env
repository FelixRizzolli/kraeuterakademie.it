# ============================================================
# Infrastructure
# ============================================================
ENVIRONMENT=production
NODE_ENV=production

# ============================================================
# Proxy
#
# Note: TRAEFIK_DASHBOARD_DOMAIN, ACME_EMAIL, and WITH_PROXY are
#       also managed as GitHub environment variables in CI and are
#       overridden automatically by the deploy workflow.
# ============================================================
WITH_PROXY=true
TRAEFIK_DASHBOARD_DOMAIN=changeme
ACME_EMAIL=changeme
# Generate with: htpasswd -nb <user> <password>
TRAEFIK_AUTH=changeme

# ============================================================
# Database (PostgreSQL)
# ============================================================
DATABASE_CLIENT=postgres
DATABASE_HOST=database
DATABASE_PORT=5432
DATABASE_USER=changeme
DATABASE_PASSWORD=changeme
DATABASE_NAMES=changeme
DATABASE_URI="postgresql://${DATABASE_USER}:${DATABASE_PASSWORD}@${DATABASE_HOST}:${DATABASE_PORT}/${DATABASE_NAMES}"

# ============================================================
# API — Payload CMS
#
# Note: PAYLOAD_DOMAIN is also managed as a GitHub environment variable
#       in CI and is overridden automatically by the deploy workflow.
# ============================================================
PAYLOAD_DOMAIN=changeme
PAYLOAD_HOST=0.0.0.0
PAYLOAD_PORT=3001
PAYLOAD_DATABASE_URI="postgresql://${DATABASE_USER}:${DATABASE_PASSWORD}@${DATABASE_HOST}:${DATABASE_PORT}/${DATABASE_NAMES}"
PAYLOAD_SECRET=changeme
CRON_SECRET=changeme
PREVIEW_SECRET=changeme

# ============================================================
# WWW — NuxtJS
#
# Note: NUXT_DOMAIN is also managed as a GitHub environment variable
#       in CI and is overridden automatically by the deploy workflow.
# ============================================================
NUXT_DOMAIN=changeme
NUXT_HOST=0.0.0.0
NUXT_PORT=3000
PAYLOAD_API_URL="https://${PAYLOAD_DOMAIN}"

# ============================================================
# Storybook — NuxtJS
#
# Note: STORYBOOK_DOMAIN is also managed as a GitHub environment variable
#       in CI and is overridden automatically by the deploy workflow.
# ============================================================
STORYBOOK_DOMAIN=changeme
